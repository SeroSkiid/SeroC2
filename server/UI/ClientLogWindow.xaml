<Window x:Class="SeroServer.UI.ClientLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Client Logs"
        Width="600" Height="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#080B15" CornerRadius="12"
            BorderBrush="#30FFFFFF" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#14FFFFFF"
                    BorderBrush="#20FFFFFF" BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="LOGS" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource BlueBrush}" />
                        <TextBlock x:Name="TxtTitle" Text="" FontSize="12" FontWeight="Light"
                                   Foreground="{StaticResource DimBrush}" Margin="8,0,0,0" />
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" Width="28" Height="24"
                            Style="{StaticResource SRedBtn}" Click="Close_Click" Padding="0"
                            FontSize="10" />
                </Grid>
            </Border>

            <!-- Log Entries -->
            <Border Grid.Row="1" Background="#0CFFFFFF" Margin="10,8,10,10" Padding="10"
                    CornerRadius="8" BorderBrush="#18FFFFFF" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtLog" Foreground="{StaticResource TextBrush}"
                               FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Window>
