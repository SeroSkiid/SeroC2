<Window x:Class="SeroServer.UI.ClientLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Client Logs"
        Width="600" Height="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="{StaticResource BgBrush}" CornerRadius="10"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Margin="14,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="LOGS" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource CyanBrush}" />
                    <TextBlock x:Name="TxtTitle" Text="" FontSize="13" FontWeight="Light"
                               Foreground="{StaticResource DimBrush}" Margin="8,0,0,0" />
                </StackPanel>
                <Button Content="X" HorizontalAlignment="Right" Width="28" Height="24"
                        Style="{StaticResource SRedBtn}" Click="Close_Click" Padding="0" />
            </Grid>

            <!-- Log Entries -->
            <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" Margin="10,0,10,10" Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtLog" Foreground="{StaticResource TextBrush}"
                               FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Window>
