<Window x:Class="SeroServer.UI.RemoteShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remote Shell"
        Width="700" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="{StaticResource BgBrush}" CornerRadius="10"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Margin="14,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="SHELL" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource CyanBrush}" />
                    <TextBlock x:Name="TxtTitle" Text="" FontSize="13" FontWeight="Light"
                               Foreground="{StaticResource DimBrush}" Margin="8,0,0,0" />
                </StackPanel>
                <Button Content="X" HorizontalAlignment="Right" Width="28" Height="24"
                        Style="{StaticResource SRedBtn}" Click="Close_Click" Padding="0" />
            </Grid>

            <!-- Output -->
            <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" Margin="10,0,10,0" Padding="8">
                <ScrollViewer x:Name="OutputScroller" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtOutput" Foreground="{StaticResource TextBrush}"
                               FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"
                               Text="Type a command and press Enter..." />
                </ScrollViewer>
            </Border>

            <!-- Command Input -->
            <Grid Grid.Row="2" Margin="10,8,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text=">" Foreground="{StaticResource CyanBrush}" FontFamily="Consolas"
                           FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Grid.Column="1" x:Name="TxtCommand" Style="{StaticResource STxt}"
                         FontFamily="Consolas" KeyDown="TxtCommand_KeyDown" />
                <Button Grid.Column="2" Content="SEND" Width="60" Margin="6,0,0,0"
                        Style="{StaticResource SGreenBtn}" Click="Send_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
