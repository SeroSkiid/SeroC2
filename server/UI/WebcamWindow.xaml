<Window x:Class="SeroServer.UI.WebcamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remote Webcam"
        Width="640" Height="500" MinWidth="400" MinHeight="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize">

    <Border x:Name="RootBorder" Background="#07090F" CornerRadius="12"
            BorderBrush="#28FFFFFF" BorderThickness="1" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="30" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- Full-window image — spans all rows so it fills the entire window -->
            <Image x:Name="ImgFrame"
                   Grid.Row="0" Grid.RowSpan="4"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"/>

            <!-- Placeholder centred over the full window -->
            <TextBlock x:Name="TxtPlaceholder"
                       Grid.Row="0" Grid.RowSpan="4"
                       Text="Waiting for device list..."
                       Foreground="{StaticResource DimBrush}" FontSize="13"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Debug log panel — overlaid at the bottom of the frame row -->
            <Border x:Name="LogPanel" Grid.Row="2" VerticalAlignment="Bottom" MaxHeight="180"
                    Background="#CC030508" Visibility="Collapsed">
                <ScrollViewer x:Name="LogScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <TextBlock x:Name="TxtLog" FontFamily="Consolas" FontSize="10"
                               Foreground="#AAFFFFFF" Padding="8,5" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <!-- ── Title bar (semi-transparent overlay) ──────────────────────── -->
            <Border Grid.Row="0" Background="#D00D1020"
                    BorderBrush="#18FFFFFF" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="WEBCAM" Foreground="{StaticResource BlueBrush}"
                                   FontSize="11" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtClientId" Text="" Foreground="{StaticResource DimBrush}"
                                   FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <Border x:Name="LiveBadge" Background="#0C2016" BorderBrush="#22C55E44"
                                BorderThickness="1" CornerRadius="3" Padding="5,1"
                                Visibility="Collapsed" VerticalAlignment="Center" Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="5" Height="5" Fill="#22C55E"
                                         Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="LIVE" Foreground="#22C55E"
                                           FontSize="9" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtFps" Text="" Foreground="{StaticResource DimBrush}"
                                   FontSize="10" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button x:Name="BtnFullscreen" Content="⛶" Width="24" Height="22" Margin="0,0,4,0"
                                Background="#0E1126" BorderBrush="#1E2240" BorderThickness="1"
                                Foreground="{StaticResource DimBrush}" FontSize="11" Cursor="Hand"
                                Click="BtnFullscreen_Click"/>
                        <Button Content="✕" Width="24" Height="22"
                                Style="{StaticResource SRedBtn}" Cursor="Hand"
                                Click="Close_Click" FontSize="10" Padding="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Control bar (semi-transparent overlay) ────────────────────── -->
            <Border Grid.Row="1" Background="#D0090B18" Padding="10,7"
                    BorderBrush="#14FFFFFF" BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="True">

                    <!-- START / STOP — right -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnStart" Content="START" Width="70" Height="24"
                                Style="{StaticResource SGreenBtn}" Click="BtnStart_Click"
                                FontSize="10" FontWeight="SemiBold" Padding="6,2"/>
                        <Button x:Name="BtnStop" Content="STOP" Width="64" Height="24" Margin="6,0,0,0"
                                Style="{StaticResource SRedBtn}" Click="BtnStop_Click"
                                IsEnabled="False" Opacity="0.35" FontSize="10" FontWeight="SemiBold" Padding="6,2"/>
                    </StackPanel>

                    <!-- Device selector — left -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock Text="DEV" Foreground="{StaticResource DimBrush}"
                                   FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <ComboBox x:Name="CmbDevice" Width="165" Height="26"
                                  FontSize="11" Style="{StaticResource SCombo}"/>
                    </StackPanel>

                    <!-- Sliders — fill centre -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Rectangle Width="1" Height="14" Fill="#16FFFFFF" Margin="0,0,10,0"/>

                        <TextBlock Text="Q" Foreground="{StaticResource DimBrush}"
                                   FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <Slider x:Name="SldQuality" Minimum="20" Maximum="95" Value="75" Width="76"
                                VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtQuality" Text="75" Width="24"
                                   Foreground="{StaticResource TextBrush}" FontSize="11"
                                   VerticalAlignment="Center" Margin="5,0,0,0"/>

                        <Rectangle Width="1" Height="14" Fill="#16FFFFFF" Margin="10,0"/>

                        <TextBlock Text="FPS" Foreground="{StaticResource DimBrush}"
                                   FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <Slider x:Name="SldFps" Minimum="5" Maximum="30" Value="20" Width="64"
                                VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtFpsVal" Text="20" Width="24"
                                   Foreground="{StaticResource TextBrush}" FontSize="11"
                                   VerticalAlignment="Center" Margin="5,0,0,0"/>

                        <Rectangle Width="1" Height="14" Fill="#16FFFFFF" Margin="10,0,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── Status bar (semi-transparent overlay) ─────────────────────── -->
            <Border Grid.Row="3" Background="#D00D1020"
                    BorderBrush="#18FFFFFF" BorderThickness="0,1,0,0">
                <Grid Margin="10,0">
                    <TextBlock x:Name="TxtStatus" Text="Waiting for device list..."
                               Foreground="{StaticResource DimBrush}" FontSize="11"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Auto-save toggle: saves one frame/sec while checked -->
                        <CheckBox x:Name="ChkAutoSave" Content="AUTO-SAVE"
                                  Foreground="#4F8EF7" FontSize="9" FontWeight="SemiBold"
                                  IsEnabled="False" Opacity="0.4" Margin="0,0,6,0" Cursor="Hand"
                                  Checked="ChkAutoSave_Changed" Unchecked="ChkAutoSave_Changed"/>
                        <Thumb Width="16" Height="16" VerticalAlignment="Bottom"
                               Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta" Opacity="0.4">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                          Stroke="#4F8EF7" StrokeThickness="1.2"/>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
