<Window x:Class="SeroServer.UI.ServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SɆⱤØ RAT"
        Icon="/sero.ico"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style TargetType="DataGridRow">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground"      Value="#DDE0F0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0F1525" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#28335A" Offset="0"/>
                                <GradientStop Color="#111830" Offset="0.6"/>
                                <GradientStop Color="#0C0D18" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Foreground"      Value="#D4DCFF" />
                    <Setter Property="BorderBrush"     Value="#4A85F5" />
                    <Setter Property="BorderThickness" Value="2,0,0,0" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected"   Value="True" />
                        <Condition Property="IsMouseOver"  Value="True" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#2E3D6A" Offset="0"/>
                                <GradientStop Color="#141E38" Offset="0.6"/>
                                <GradientStop Color="#0F1020" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="10,6" BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#C8CEFA" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background"      Value="#0F1020" />
            <Setter Property="BorderBrush"     Value="#1E2038" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground"      Value="#DDE0F0" />
            <Setter Property="Padding"         Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#0F1020" BorderBrush="#1E2038" BorderThickness="1"
                                CornerRadius="10" Padding="4">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="28" ShadowDepth="8" Opacity="0.75" Color="#000000"/>
                            </Border.Effect>
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#DDE0F0"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6" Margin="1,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Icon column -->
                                <ContentPresenter Grid.Column="0"
                                                  ContentSource="Icon"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                <!-- Text column -->
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  Margin="2,8,16,8"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#181B34"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.38"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ── Window chrome ──────────────────────────────────────────── -->
    <Border Background="#0C0D18" CornerRadius="10" BorderThickness="1">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#50FFFFFF" Offset="0"/>
                <GradientStop Color="#0A1E2038" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="3"  />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*"  />
                <RowDefinition Height="28" />
            </Grid.RowDefinitions>

            <!-- ── Background ─────────────────────────────────────────── -->
            <Grid Grid.RowSpan="5" IsHitTestVisible="False" ClipToBounds="True">

                <Rectangle Fill="#0C0D18"/>

                <!-- Logo watermark centré -->
                <Image x:Name="BgLogoImage"
                       Source="/serofondtransparent.png"
                       Width="460" Height="460"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="0,55,0,0"
                       Opacity="0.52"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Effect>
                        <BlurEffect x:Name="BgLogoBlur" Radius="2"/>
                    </Image.Effect>
                </Image>

            </Grid>

            <!-- ── Title bar ──────────────────────────────────────── -->
            <Border Grid.Row="0" Background="#C0111222" CornerRadius="10,10,0,0"
                    BorderThickness="0,0,0,1">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#281E2038" Offset="0"/>
                        <GradientStop Color="#1E2038"   Offset="0.5"/>
                        <GradientStop Color="#281E2038" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/icone.png" Width="26" Height="26" Margin="0,0,9,0"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Clip>
                                <RectangleGeometry RadiusX="5" RadiusY="5" Rect="0,0,26,26" />
                            </Image.Clip>
                        </Image>
                        <TextBlock VerticalAlignment="Center" FontSize="14" FontWeight="Bold">
                            <Run Text="SɆⱤØ">
                                <Run.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#4A85F5" Offset="0"/>
                                        <GradientStop Color="#7C5CE8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Run.Foreground>
                            </Run>
                            <Run Text="RAT">
                                <Run.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#D8DCF0" Offset="0"/>
                                        <GradientStop Color="#8890B8" Offset="0.5"/>
                                        <GradientStop Color="#C4C8E0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Run.Foreground>
                            </Run>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,-2,0">
                        <Button Content="─" Width="32" Height="26" Style="{StaticResource SBtn}"
                                Click="Minimize_Click" Padding="0" FontSize="11" />
                        <Button x:Name="BtnFullscreen" Content="☐" Width="32" Height="26" Style="{StaticResource SBtn}"
                                Click="Fullscreen_Click" Padding="0" Margin="2,0,0,0" FontSize="11" />
                        <Button Content="✕" Width="32" Height="26" Style="{StaticResource SRedBtn}"
                                Click="Close_Click" Padding="0" Margin="2,0,0,0" FontSize="11" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Accent line: full-width repeating aurora ─────────── -->
            <!--  Single stretch rectangle, gradient SpreadMethod=Repeat,
                  brush transform scrolls → always covers full width, zero gap -->
            <Rectangle x:Name="AuroraBar" Grid.Row="1" Height="3">
                <Rectangle.Fill>
                    <LinearGradientBrush MappingMode="Absolute"
                                         StartPoint="0,0" EndPoint="600,0"
                                         SpreadMethod="Repeat">
                        <LinearGradientBrush.Transform>
                            <TranslateTransform X="0"/>
                        </LinearGradientBrush.Transform>
                        <GradientStop Color="#4A85F5" Offset="0.00"/>
                        <GradientStop Color="#0DCCFF" Offset="0.20"/>
                        <GradientStop Color="#7C5CE8" Offset="0.42"/>
                        <GradientStop Color="#D040FF" Offset="0.58"/>
                        <GradientStop Color="#7C5CE8" Offset="0.76"/>
                        <GradientStop Color="#0DCCFF" Offset="0.90"/>
                        <GradientStop Color="#4A85F5" Offset="1.00"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
                <Rectangle.Triggers>
                    <EventTrigger RoutedEvent="Rectangle.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetName="AuroraBar"
                                    Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.Transform).(TranslateTransform.X)"
                                    From="0" To="-600" Duration="0:0:5"
                                    RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Rectangle.Triggers>
            </Rectangle>

            <!-- ── Control bar ────────────────────────────────────── -->
            <Border Grid.Row="2" Background="#C0111222" Padding="16,8"
                    BorderThickness="0,0,0,1">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#281E2038" Offset="0"/>
                        <GradientStop Color="#1E2038"   Offset="0.5"/>
                        <GradientStop Color="#281E2038" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="PORT" Foreground="#606880" VerticalAlignment="Center"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,8,0" />
                        <TextBox x:Name="TxtPort" Style="{StaticResource STxt}" Width="64" Text="7777" />
                        <Button x:Name="BtnStartStop" Content="START"
                                Style="{StaticResource SGreenBtn}" Click="StartStop_Click"
                                Width="80" Height="30" Margin="8,0,0,0" />
                    </StackPanel>

                    <!-- Status pill with pulsing dot -->
                    <Border Grid.Column="1" Background="#0D0E1A" CornerRadius="20" Padding="18,6"
                            BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#301E2038" Offset="0"/>
                                <GradientStop Color="#101E2038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0">
                                <Ellipse x:Name="ServerPulse" Stroke="#EF4444" StrokeThickness="1.2"
                                         Fill="Transparent" Opacity="0" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform x:Name="PulseScale"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <Ellipse x:Name="ServerDot" Width="7" Height="7" Fill="#EF4444"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Grid.Triggers>
                                    <EventTrigger RoutedEvent="Grid.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="PulseScale"
                                                                 Storyboard.TargetProperty="ScaleX"
                                                                 From="0.4" To="2.2" Duration="0:0:1.4"/>
                                                <DoubleAnimation Storyboard.TargetName="PulseScale"
                                                                 Storyboard.TargetProperty="ScaleY"
                                                                 From="0.4" To="2.2" Duration="0:0:1.4"/>
                                                <DoubleAnimation Storyboard.TargetName="ServerPulse"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 From="0.65" To="0.0" Duration="0:0:1.4"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Grid.Triggers>
                            </Grid>
                            <TextBlock x:Name="TxtServerStatus" Text="Stopped"
                                       Foreground="#606880" FontSize="12" />
                            <TextBlock x:Name="TxtClientCount" Text="  ·  0 clients"
                                       Foreground="#606880" FontSize="12" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Button Content="Backup" Style="{StaticResource SBtn}" Height="30"
                                Click="ExportBackup_Click" ToolTip="Export cert + auth key (.sero)" />
                        <Button Content="Import" Style="{StaticResource SBtn}" Height="30" Margin="6,0,0,0"
                                Click="ImportBackup_Click" ToolTip="Import .sero backup or .pfx cert" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Tab control ────────────────────────────────────── -->
            <TabControl x:Name="MainTabControl" Grid.Row="3" Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource TextBrush}"
                        SelectionChanged="MainTabControl_SelectionChanged">
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <ScrollViewer Grid.Row="0"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Background="#C0111222"
                                          Focusable="False">
                                <StackPanel Orientation="Horizontal"
                                            IsItemsHost="True"/>
                            </ScrollViewer>
                            <Rectangle Grid.Row="1" Height="1">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#301E2038"   Offset="0.2"/>
                                        <GradientStop Color="#1E2038"     Offset="0.5"/>
                                        <GradientStop Color="#301E2038"   Offset="0.8"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Grid.Row="2"
                                              ContentSource="SelectedContent"
                                              ContentTemplate="{TemplateBinding SelectedContentTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Foreground" Value="#606880" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Padding"    Value="14,10" />
                        <Setter Property="FontSize"   Value="12" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Grid x:Name="root" Cursor="Hand">
                                        <Border x:Name="bd" Background="Transparent"
                                                Padding="{TemplateBinding Padding}" />
                                        <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Margin="{TemplateBinding Padding}" />
                                        <Rectangle x:Name="line" Height="3" VerticalAlignment="Bottom"
                                                   Visibility="Collapsed"
                                                   Fill="{StaticResource AccentBarBrush}" />
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Foreground" Value="#EEF0FF" />
                                            <Setter TargetName="bd"   Property="Background"  Value="#181B30" />
                                            <Setter TargetName="line" Property="Visibility"  Value="Visible" />
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True" />
                                                <Condition Property="IsSelected"  Value="False" />
                                            </MultiTrigger.Conditions>
                                            <Setter Property="Foreground" Value="#A0AACE" />
                                            <Setter TargetName="bd" Property="Background" Value="#10121E" />
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- ── Dashboard ── -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="▦" Foreground="#4A85F5" FontSize="10" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="8" Padding="24" CornerRadius="8"
                            Background="#D0111222" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#283040FF" Offset="0"/>
                                <GradientStop Color="#121E2038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <StackPanel>
                            <TextBlock Text="OVERVIEW" Style="{StaticResource SLabel}" Margin="0,0,0,20" />
                            <UniformGrid Columns="3">
                                <Border Background="#0A0D1A" CornerRadius="7" Padding="0,20"
                                        Margin="0,0,10,0" BorderThickness="1">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#4022C55E" Offset="0"/>
                                            <GradientStop Color="#0A22C55E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="ONLINE" Foreground="#8090B4" FontSize="10"
                                                   FontWeight="SemiBold" HorizontalAlignment="Center" />
                                        <TextBlock x:Name="DashOnline" Text="0" Foreground="#22C55E"
                                                   FontSize="38" FontWeight="Bold"
                                                   Margin="0,8,0,0" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#0A0D1A" CornerRadius="7" Padding="0,20"
                                        Margin="0,0,10,0" BorderThickness="1">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#404A85F5" Offset="0"/>
                                            <GradientStop Color="#0A4A85F5" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="TOTAL SEEN" Foreground="#8090B4" FontSize="10"
                                                   FontWeight="SemiBold" HorizontalAlignment="Center" />
                                        <TextBlock x:Name="DashTotal" Text="0" Foreground="#4A85F5"
                                                   FontSize="38" FontWeight="Bold"
                                                   Margin="0,8,0,0" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#0A0D1A" CornerRadius="7" Padding="0,20"
                                        BorderThickness="1">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#407C5CE8" Offset="0"/>
                                            <GradientStop Color="#0A7C5CE8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="UPTIME" Foreground="#8090B4" FontSize="10"
                                                   FontWeight="SemiBold" HorizontalAlignment="Center" />
                                        <TextBlock x:Name="DashUptime" Text="--" Foreground="#7C5CE8"
                                                   FontSize="28" FontWeight="Bold"
                                                   Margin="0,12,0,0" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- ── Online ── -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="◉" Foreground="#22C55E" FontSize="10" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Online"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="8" CornerRadius="8"
                            Background="#D0111222" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#283040FF" Offset="0"/>
                                <GradientStop Color="#121E2038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#0D0E1A"
                                    BorderBrush="#1E2038" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="⌕" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="#606880" />
                                    <TextBox Grid.Column="1" x:Name="TxtSearch"
                                             Background="Transparent" Foreground="#DDE0F0"
                                             BorderThickness="0" Padding="0,9"
                                             FontSize="12" CaretBrush="#4A85F5" SelectionBrush="#4A85F5"
                                             VerticalContentAlignment="Center"
                                             TextChanged="TxtSearch_TextChanged"
                                             KeyDown="TxtSearch_KeyDown">
                                        <TextBox.Template>
                                            <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                    <TextBlock x:Name="Placeholder"
                                                               Text="Search  IP · ID · Tag · Machine · Country · Window..."
                                                               Foreground="#606880" FontSize="12"
                                                               VerticalAlignment="Center"
                                                               Visibility="Collapsed" IsHitTestVisible="False" />
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Padding="0,9" VerticalAlignment="Center" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </TextBox.Template>
                                    </TextBox>
                                </Grid>
                            </Border>

                            <DataGrid Grid.Row="1" x:Name="GridClients"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      PreviewKeyDown="GridClients_PreviewKeyDown"
                                      Background="Transparent" Foreground="#DDE0F0"
                                      BorderThickness="0" RowBackground="Transparent"
                                      AlternatingRowBackground="#07101428"
                                      GridLinesVisibility="None" HeadersVisibility="Column"
                                      FontSize="12" SelectionMode="Extended" CanUserAddRows="False"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.CanContentScroll="True"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ColumnHeaderStyle="{StaticResource SColHeader}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID"         Binding="{Binding Id}"                                 Width="65"  />
                                    <DataGridTextColumn Header="TAG"        Binding="{Binding Tag}"                                Width="75"  />
                                    <DataGridTextColumn Header="USER"       Binding="{Binding Username}"                           Width="110" />
                                    <DataGridTextColumn Header="IP"         Binding="{Binding IP}"                                 Width="115" />
                                    <DataGridTextColumn Header="PRIVILEGE" Binding="{Binding Privilege}" Width="80" />
                                    <DataGridTextColumn Header="COUNTRY"    Binding="{Binding CountryDisplay}"                     Width="120" />
                                    <DataGridTextColumn Header="MACHINE"    Binding="{Binding MachineName}"                        Width="130" />
                                    <DataGridTextColumn Header="OS"         Binding="{Binding OS}"                                 Width="120" />
                                    <DataGridTextColumn Header="PAYLOAD"    Binding="{Binding Payload}"                            Width="110" />
                                    <DataGridTextColumn Header="ANTIVIRUS"  Binding="{Binding Antivirus}"                          Width="120" />
                                    <DataGridTextColumn Header="1ST SEEN"   Binding="{Binding FirstSeen, StringFormat=yyyy-MM-dd}" Width="88"  />
                                    <DataGridTextColumn Header="CAMERA"     Binding="{Binding CameraStatus}"                       Width="68"  />
                                    <DataGridTextColumn Header="WINDOW"     Binding="{Binding ActiveWindow}"                       Width="150" />
                                    <DataGridTemplateColumn Header="PING"   Width="75" MinWidth="55" SortMemberPath="PingMs">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding PingDisplay}"
                                                           Foreground="{Binding PingBrush}"
                                                           FontFamily="Consolas" FontSize="11"
                                                           VerticalAlignment="Center" Margin="10,0" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Remote Shell"          Click="RemoteShell_Click" />
                                        <MenuItem Header="Remote Desktop"        Click="RemoteDesktop_Click" />
                                        <MenuItem Header="Remote Webcam"         Click="RemoteWebcam_Click" />
                                        <MenuItem Header="HVNC"                  Click="Hvnc_Click" />
                                        <Separator />
                                        <MenuItem Header="Remote File Execute"   Click="RemoteFileExec_Click" />
                                        <MenuItem Header="Update Client (file)"  Click="UpdateClient_Click" />
                                        <Separator />
                                        <MenuItem Header="Request Elevation (UAC)"   Click="RequestElevation_Click" />
                                        <MenuItem Header="Loop UAC Until Accept"     Click="RequestElevationLoop_Click" />
                                        <Separator />
                                        <MenuItem Header="Run BotKiller"         Click="BotKiller_Click"
                                                  ToolTip="Compile and send BotKiller to selected client(s): kills unsigned+random-name processes." />
                                        <Separator />
                                        <MenuItem Header="Set Tag"               Click="SetTag_Click" />
                                        <MenuItem Header="View Logs"             Click="ViewClientLogs_Click" />
                                        <Separator />
                                        <MenuItem Header="Uninstall Client"      Click="UninstallClient_Click" />
                                        <MenuItem Header="Disconnect"            Click="DisconnectClient_Click" />
                                        <Separator />
                                        <MenuItem Header="Copy IP"               Click="CopyIP_Click" />
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                            </DataGrid>

                            <!-- Empty state overlay for Online -->
                            <Grid Grid.Row="1" IsHitTestVisible="False">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Items.Count, ElementName=GridClients}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.4">
                                    <TextBlock Text="⊘" FontSize="40" Foreground="#606880" HorizontalAlignment="Center"/>
                                    <TextBlock Text="No clients connected" Foreground="#606880" FontSize="13"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- ── All Clients ── -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="≡" Foreground="#606880" FontSize="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="All Clients"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="8" CornerRadius="8"
                            Background="#D0111222" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#283040FF" Offset="0"/>
                                <GradientStop Color="#121E2038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Grid>
                            <DataGrid x:Name="GridAllClients"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      Background="Transparent" Foreground="#DDE0F0"
                                      BorderThickness="0" RowBackground="Transparent"
                                      AlternatingRowBackground="#07101428"
                                      GridLinesVisibility="None" HeadersVisibility="Column"
                                      FontSize="12" SelectionMode="Extended" CanUserAddRows="False"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.CanContentScroll="True"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ColumnHeaderStyle="{StaticResource SColHeader}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="TAG"        Binding="{Binding Tag}"                                          Width="90"  />
                                    <DataGridTextColumn Header="USER"       Binding="{Binding LastUsername}"                                 Width="130" />
                                    <DataGridTextColumn Header="IP"         Binding="{Binding LastIP}"                                       Width="130" />
                                    <DataGridTextColumn Header="COUNTRY"    Binding="{Binding LastCountry}"                                  Width="120" />
                                    <DataGridTextColumn Header="MACHINE"    Binding="{Binding LastMachineName}"                              Width="140" />
                                    <DataGridTextColumn Header="OS"         Binding="{Binding LastOS}"                                       Width="140" />
                                    <DataGridTextColumn Header="FIRST SEEN" Binding="{Binding FirstSeen, StringFormat=yyyy-MM-dd HH:mm}"     Width="*"   />
                                    <DataGridTextColumn Header="LAST SEEN"  Binding="{Binding LastSeen,  StringFormat=yyyy-MM-dd HH:mm}"     Width="*"   />
                                </DataGrid.Columns>
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Set Tag"    Click="SetTagRecord_Click" />
                                        <MenuItem Header="View Logs"  Click="ViewRecordLogs_Click" />
                                        <Separator />
                                        <MenuItem Header="Copy HWID"  Click="CopyRecordHwid_Click" />
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                            </DataGrid>

                            <!-- Empty state overlay for All Clients -->
                            <Grid IsHitTestVisible="False">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Items.Count, ElementName=GridAllClients}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.4">
                                    <TextBlock Text="⊘" FontSize="40" Foreground="#606880" HorizontalAlignment="Center"/>
                                    <TextBlock Text="No records found" Foreground="#606880" FontSize="13"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- ── Builder ── -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⬧" Foreground="#7C5CE8" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Builder"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="8" Padding="20" CornerRadius="8"
                            Background="#D0111222" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#283040FF" Offset="0"/>
                                <GradientStop Color="#121E2038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid x:Name="BuilderPanel" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="260"/>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*" MinWidth="260"/>
                                </Grid.ColumnDefinitions>

                                <Rectangle Grid.Column="1" Width="1" HorizontalAlignment="Center"
                                           VerticalAlignment="Stretch" Margin="0,4">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="Transparent" Offset="0" />
                                            <GradientStop Color="#1E2038"     Offset="0.15" />
                                            <GradientStop Color="#1E2038"     Offset="0.85" />
                                            <GradientStop Color="Transparent" Offset="1" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="CONNECTION" Style="{StaticResource SLabel}" />
                                    <TextBlock Text="HOSTS" Style="{StaticResource SFieldLabel}" />
                                    <ListBox x:Name="BldHosts" Style="{StaticResource SListBox}" Height="96" Margin="0,0,0,8" />
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="BldHostInput" Style="{StaticResource STxt}" />
                                        <Button Grid.Column="1" Content="+" Width="44" Margin="6,0,0,0" Style="{StaticResource SBtn}" Click="BldAddHost_Click" />
                                        <Button Grid.Column="2" Content="−" Width="44" Margin="4,0,0,0" Style="{StaticResource SBtn}" Click="BldDelHost_Click" />
                                    </Grid>
                                    <TextBlock Text="PORT" Style="{StaticResource SFieldLabel}" />
                                    <TextBox x:Name="BldPort" Style="{StaticResource STxt}" Text="7777" Margin="0,0,0,8" />
                                    <CheckBox x:Name="BldUsePastebin" Content="Use Pastebin (disables direct connection)" Style="{StaticResource SChk}" IsChecked="False" Checked="BldUsePastebin_Checked" Unchecked="BldUsePastebin_Unchecked" Margin="0,0,0,6" />
                                    <TextBlock Text="PASTEBIN URL" Style="{StaticResource SFieldLabel}" />
                                    <TextBox x:Name="BldPastebinUrl" Style="{StaticResource STxt}" Text="https://pastebin.com/raw/YourURL" IsEnabled="False" Margin="0,0,0,16" />

                                    <TextBlock Text="IDENTITY" Style="{StaticResource SLabel}" />
                                    <TextBlock Text="CLIENT ID PREFIX" Style="{StaticResource SFieldLabel}" />
                                    <TextBox x:Name="BldClientIdPrefix" Style="{StaticResource STxt}" Margin="0,0,0,14" />
                                    <CheckBox x:Name="BldSetAssembly" Content="Copy assembly metadata from executable" Style="{StaticResource SChk}" Checked="BldSetAssembly_Checked" Unchecked="BldSetAssembly_Unchecked" />
                                    <TextBlock x:Name="BldAssemblyPath" Text="No executable selected" Foreground="#7880A8" Margin="0,0,0,12" FontSize="11" />
                                    <CheckBox x:Name="BldSetIcon" Content="Set custom icon from .ico file" Style="{StaticResource SChk}" Checked="BldSetIcon_Checked" Unchecked="BldSetIcon_Unchecked" />
                                    <TextBlock x:Name="BldIconPath" Text="No icon selected" Foreground="#7880A8" Margin="0,0,0,12" FontSize="11" />
                                    <CheckBox x:Name="BldUseMutex" Content="Use Mutex" Style="{StaticResource SChk}" IsChecked="True" />
                                    <TextBlock Text="MUTEX" Style="{StaticResource SFieldLabel}" Margin="0,4,0,4" />
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="BldMutex" Style="{StaticResource STxt}"
                                                 Text="Global\{B7E9F3A1-4D2C-4A8E-9F1B-3C5D7E2A6B8F}" />
                                        <Button Grid.Column="1" Content="GEN" Width="60" Margin="6,0,0,0"
                                                Style="{StaticResource SBtn}" Click="BldGenMutex_Click" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="PROCESS HOLLOWING" Style="{StaticResource SLabel}" />
                                    <CheckBox x:Name="BldHollowing" Content="Auto-inject into legitimate process" Style="{StaticResource SChk}" />
                                    <StackPanel Margin="0,4,0,14"
                                                Visibility="{Binding IsChecked, ElementName=BldHollowing, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="TARGET PROCESS" Style="{StaticResource SFieldLabel}" />
                                        <ComboBox x:Name="BldHollowTarget" MaxDropDownHeight="460"
                                                  IsEditable="True" Text=""
                                                  FontFamily="Consolas" FontSize="11"
                                                  Background="White" Foreground="#111111"
                                                  BorderBrush="#1E2038" BorderThickness="1">
                                            <ComboBox.Resources>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"          Color="White"/>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"      Color="#111111"/>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"       Color="#E0E8FF"/>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"   Color="#111111"/>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"         Color="White"/>
                                            </ComboBox.Resources>
                                            <ComboBox.ItemContainerStyle>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="Foreground" Value="#111111"/>
                                                    <Setter Property="Padding"    Value="6,5"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ComboBoxItem">
                                                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsHighlighted" Value="True">
                                                                        <Setter TargetName="bd" Property="Background" Value="#E0E8FF"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter TargetName="bd" Property="Background" Value="#C8D8FF"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ComboBox.ItemContainerStyle>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid MinWidth="360">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="180" />
                                                            <ColumnDefinition Width="50" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Proc}" FontWeight="SemiBold"
                                                                   Foreground="#111111" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Score}" Foreground="{Binding ScoreColor}"
                                                                   FontWeight="Bold" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="2" Text="{Binding Note}" Foreground="#667088"
                                                                   FontFamily="Consolas" FontSize="10" VerticalAlignment="Center" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <TextBlock Text="PROTECTION" Style="{StaticResource SLabel}" Margin="0,8,0,8" />
                                    <CheckBox x:Name="BldAntiDebug"   Content="Anti-Debug"                                     Style="{StaticResource SChk}" IsChecked="True" />
                                    <CheckBox x:Name="BldAntiVM"      Content="Anti-VM"                                        Style="{StaticResource SChk}" IsChecked="True" />
                                    <CheckBox x:Name="BldAntiDetect"  Content="Anti-Detect (analysis tools)"                   Style="{StaticResource SChk}" IsChecked="True" />
                                    <CheckBox x:Name="BldAntiSandbox" Content="Anti-Sandbox"                                   Style="{StaticResource SChk}" IsChecked="True" />
                                    <CheckBox x:Name="BldAntiKill"    Content="Anti-Kill"                                      Style="{StaticResource SChk}" IsChecked="False"
                                              ToolTip="DACL (deny TERMINATE) + guardian + WMI persistence. Redémarre le process s'il est tué."
                                              Checked="BldPersist_Changed" Unchecked="BldPersist_Changed" />
                                    <TextBlock x:Name="TxtMaxPersist" Margin="18,2,0,10" FontSize="10"
                                               Foreground="#22C55E" FontWeight="SemiBold"
                                               Text="✓ Persistance maximale" Visibility="Collapsed" />

                                    <TextBlock Text="OBFUSCATION" Style="{StaticResource SLabel}" Margin="0,8,0,8" />
                                    <CheckBox x:Name="BldEncrypt"   Content="Crypter (AES-256, junk code, polymorphic, pumped)"                     Style="{StaticResource SChk}" />
                                    <CheckBox x:Name="BldUacBypass" Content="UAC Bypass + SYSTEM elevation (fodhelper + winlogon token)"     Style="{StaticResource SChk}"
                                              ToolTip="① fodhelper UAC bypass (ms-settings HKCU hijack). ② SeDebugPrivilege + vol de token winlogon.exe pour SYSTEM." />
                                    <Border Margin="18,2,0,12" Padding="8,5"
                                            Background="#1AF59E0B" BorderBrush="#60F59E0B"
                                            BorderThickness="1" CornerRadius="5"
                                            Visibility="{Binding IsChecked, ElementName=BldUacBypass, Converter={StaticResource BoolToVis}}">
                                        <TextBlock FontSize="10" Foreground="#F59E0B" TextWrapping="Wrap"
                                                   Text="⚠  UAC bypass utilise le loader natif C++ — le crypter sera appliqué automatiquement." />
                                    </Border>

                                    <TextBlock Text="PERSISTENCE" Style="{StaticResource SLabel}" Margin="0,4,0,8" />
                                    <CheckBox x:Name="BldPersistRegistry" Content="Registry (HKCU\Run)"  Style="{StaticResource SChk}" Checked="BldPersist_Changed" Unchecked="BldPersist_Changed" />
                                    <CheckBox x:Name="BldPersistStartup"  Content="Startup Folder"       Style="{StaticResource SChk}" Checked="BldPersist_Changed" Unchecked="BldPersist_Changed" />
                                    <CheckBox x:Name="BldPersistTask"     Content="Scheduled Task"        Style="{StaticResource SChk}" IsChecked="True" Checked="BldPersist_Changed" Unchecked="BldPersist_Changed" />
                                    <StackPanel x:Name="BldInstallPanel">
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                            <TextBlock Text="Install folder: " Foreground="#606880" FontSize="12" VerticalAlignment="Center" Width="90" />
                                            <TextBox x:Name="BldInstallFolder" Style="{StaticResource STxt}" Width="160" Text="Windows" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                            <TextBlock Text="File name:      " Foreground="#606880" FontSize="12" VerticalAlignment="Center" Width="90" />
                                            <TextBox x:Name="BldInstallFileName" Style="{StaticResource STxt}" Width="160" Text="windows.exe" />
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBox x:Name="BldAuthKey"  Visibility="Collapsed" />
                                    <TextBox x:Name="BldCertHash" Visibility="Collapsed" />

                                    <TextBlock Text="RECONNECT" Style="{StaticResource SLabel}" Margin="0,4,0,8" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <TextBlock Text="Delay (ms):" Foreground="#606880" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBox x:Name="BldReconnectDelay" Style="{StaticResource STxt}" Width="70" Text="5000" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="BtnBuild" Content="BUILD" Width="120" Height="34"
                                                Style="{StaticResource SGreenBtn}" Click="Build_Click" />
                                        <Button Content="SAVE"      Width="70" Height="34" Margin="8,0,0,0" Style="{StaticResource SBtn}" Click="BldSaveConfig_Click" />
                                        <Button Content="CHECK ALL" Width="96" Height="34" Margin="8,0,0,0" Style="{StaticResource SBtn}" Click="BldCheckAll_Click" />
                                    </StackPanel>
                                    <TextBlock x:Name="TxtBuildStatus" Text="" Foreground="#606880"
                                               FontSize="11" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,12,0,0" />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <!-- ── AutoTask ── -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="▷" Foreground="#F59E0B" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="AutoTask"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="8" Padding="20" CornerRadius="8"
                            Background="#D0111222" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#283040FF" Offset="0"/>
                                <GradientStop Color="#121E2038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,0,14">
                                <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,8">
                                    <Button Content="ADD FILE"     Height="30" Margin="4" Style="{StaticResource SGreenBtn}" Click="AutoTask_AddFile_Click" />
                                    <Button Content="EXCLUDE C:"   Height="30" Margin="4" Style="{StaticResource SGreenBtn}" Click="AutoTask_ExcludeCDrive_Click"
                                            ToolTip="Exclude C:\ from Defender via C++ DLL plugin (SYSTEM token, WMI)." />
                                    <Button Content="DISABLE UAC"  Height="30" Margin="4" Style="{StaticResource SGreenBtn}" Click="AutoTask_DisableUAC_Click" />
                                    <Button Content="BLOCK AV DNS" Height="30" Margin="4" Style="{StaticResource SGreenBtn}" Click="AutoTask_BlockAvDomains_Click" />
                                    <Button Content="BLOCK RESET"  Height="30" Margin="4" Style="{StaticResource SGreenBtn}" Click="AutoTask_BlockReset_Click"
                                            ToolTip="Disable Windows Recovery (reagentc /disable)" />
                                    <Button Content="BOTKILLER"    Height="30" Margin="4" Style="{StaticResource SGreenBtn}" Click="AutoTask_BotKiller_Click"
                                            ToolTip="Kill known RATs/miners, remove their persistence from Run keys and startup folder." />
                                    <Button Content="REMOVE"       Height="30" Margin="4" Style="{StaticResource SBtn}"      Click="AutoTask_Remove_Click" />
                                </WrapPanel>
                                <TextBlock Text="Tasks execute once per HWID"
                                           Foreground="#606880" FontSize="11"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <DataGrid x:Name="GridAutoTasks" Grid.Row="1"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      Background="Transparent" Foreground="#DDE0F0"
                                      BorderThickness="0" RowBackground="Transparent"
                                      AlternatingRowBackground="#07101428"
                                      GridLinesVisibility="None" HeadersVisibility="Column"
                                      FontSize="12" SelectionMode="Extended" CanUserAddRows="False"
                                      ColumnHeaderStyle="{StaticResource SColHeader}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="NAME"       Binding="{Binding FileName}"                                Width="*"   />
                                    <DataGridTextColumn Header="TYPE"       Binding="{Binding TypeDisplay}"                             Width="110" />
                                    <DataGridTextColumn Header="SIZE"       Binding="{Binding SizeDisplay}"                             Width="90"  />
                                    <DataGridTextColumn Header="EXECUTIONS" Binding="{Binding ExecutionCount}"                          Width="100" />
                                    <DataGridTextColumn Header="ADDED"      Binding="{Binding AddedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="140" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- ── Settings ── -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⚙" Foreground="#606880" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="8" Padding="32" CornerRadius="8"
                            Background="#D0111222" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#283040FF" Offset="0"/>
                                <GradientStop Color="#121E2038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <StackPanel MaxWidth="520" HorizontalAlignment="Center">
                            <TextBlock Text="SERVER LIMITS" Style="{StaticResource SLabel}" />
                            <TextBlock Text="MAX CONNECTED CLIENTS" Style="{StaticResource SFieldLabel}" />
                            <TextBox x:Name="SettingsMaxClients" Style="{StaticResource STxt}" Text="1000" Width="120" HorizontalAlignment="Left" Margin="0,0,0,6" />
                            <TextBlock Text="Rejects new connections when this limit is reached." Foreground="#606880" FontSize="11" Margin="0,0,0,24" />

                            <TextBlock Text="INTEGRATIONS" Style="{StaticResource SLabel}" />
                            <CheckBox x:Name="SettingsDiscordRPC" Content="Discord Rich Presence" Style="{StaticResource SChk}" Margin="0,0,0,24" />

                            <TextBlock Text="PORT CHECKER" Style="{StaticResource SLabel}" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBox x:Name="SettingsCheckIP"   Style="{StaticResource STxt}" Width="160" Text="127.0.0.1" />
                                <TextBlock Text=":" Foreground="#606880" FontSize="16" VerticalAlignment="Center" Margin="8,0" />
                                <TextBox x:Name="SettingsCheckPort" Style="{StaticResource STxt}" Width="64" Text="7777" />
                                <Button Content="CHECK" Height="32" Margin="10,0,0,0" Style="{StaticResource SGreenBtn}" Click="CheckPort_Click" />
                                <Button Content="GET IP" Height="32" Margin="8,0,0,0"  Style="{StaticResource SBtn}"      Click="GetMyIP_Click" />
                            </StackPanel>
                            <TextBlock x:Name="TxtPortResult" Text="" Foreground="#606880" FontSize="12" Margin="0,4,0,24" />

                            <Button Content="APPLY" Height="32" Width="100" Style="{StaticResource SGreenBtn}" Click="SettingsApply_Click" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- ── Logs ── -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="≋" Foreground="#606880" FontSize="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Logs"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="8" Padding="12" CornerRadius="8"
                            Background="#D0111222" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#283040FF" Offset="0"/>
                                <GradientStop Color="#121E2038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="TxtLogs" Foreground="#606880"
                                       FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <!-- ── About ── -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="✦" Foreground="#7C5CE8" FontSize="10" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="About"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="8" CornerRadius="8"
                            Background="#D0111222" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#283040FF" Offset="0"/>
                                <GradientStop Color="#121E2038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel HorizontalAlignment="Center"
                                        Margin="20,28,20,28">

                                <!-- Developer photo -->
                                <Grid HorizontalAlignment="Center" Margin="0,0,0,18">
                                    <Ellipse Width="168" Height="168" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#304A85F5" Offset="0.6"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <Border Width="150" Height="150" CornerRadius="75"
                                            BorderThickness="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#4A85F5" Offset="0"/>
                                                <GradientStop Color="#C44BFF" Offset="0.5"/>
                                                <GradientStop Color="#7C5CE8" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <Border.Background>
                                            <ImageBrush ImageSource="/photo.png"
                                                        Stretch="UniformToFill"
                                                        AlignmentX="Center" AlignmentY="Top"
                                                        RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border.Background>
                                        <Border.Clip>
                                            <EllipseGeometry Center="75,75" RadiusX="75" RadiusY="75"/>
                                        </Border.Clip>
                                    </Border>
                                </Grid>

                                <!-- Title -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                    <TextBlock VerticalAlignment="Center" FontSize="24" FontWeight="Bold">
                                        <Run Text="SɆⱤØ">
                                            <Run.Foreground>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#4A85F5" Offset="0"/>
                                                    <GradientStop Color="#7C5CE8" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Run.Foreground>
                                        </Run>
                                        <Run Text="RAT">
                                            <Run.Foreground>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#D8DCF0" Offset="0"/>
                                                    <GradientStop Color="#8890B8" Offset="0.5"/>
                                                    <GradientStop Color="#C4C8E0" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Run.Foreground>
                                        </Run>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock HorizontalAlignment="Center" Margin="0,0,0,20"
                                           FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#7A8AB8" Offset="0"/>
                                            <GradientStop Color="#9AABCC" Offset="0.5"/>
                                            <GradientStop Color="#7A8AB8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                    REMOTE ACCESS TROJAN
                                </TextBlock>

                                <!-- Divider -->
                                <Rectangle Height="1" MaxWidth="320" HorizontalAlignment="Center" Margin="0,0,0,18">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="Transparent" Offset="0"/>
                                            <GradientStop Color="#3A4080"     Offset="0.5"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>

                                <!-- Description -->
                                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,22" MaxWidth="360">
                                    <TextBlock TextAlignment="Center" HorizontalAlignment="Center"
                                               FontSize="13" FontStyle="Italic" Foreground="#A8B0CC" Margin="0,0,0,5">
                                        Powerful lightweight and polymorphic x64 RAT
                                    </TextBlock>
                                    <TextBlock TextAlignment="Center" HorizontalAlignment="Center"
                                               FontSize="11" Foreground="#5A6080" Margin="0,0,0,12">
                                        Crafted by Serotonine, Cool French Developer
                                    </TextBlock>
                                    <TextBlock TextAlignment="Center" HorizontalAlignment="Center"
                                               FontSize="11" FontWeight="Bold" Foreground="#BCC4E0" Margin="0,0,0,12">
                                        I'm not responsible for any misuse of this tool
                                    </TextBlock>

                                    <!-- 2-column feature grid — half the vertical space -->
                                    <Border CornerRadius="8" Padding="18,10" HorizontalAlignment="Center" BorderThickness="1">
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#30404A85" Offset="0"/>
                                                <GradientStop Color="#307C5CE8" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <Border.Background>
                                            <SolidColorBrush Color="#060810"/>
                                        </Border.Background>
                                        <UniformGrid Columns="2">
                                            <TextBlock Text="▸  Remote Shell"      Foreground="#8890B0" FontSize="11" Margin="0,3,14,3"/>
                                            <TextBlock Text="▸  Remote Desktop"    Foreground="#8890B0" FontSize="11" Margin="0,3,0,3"/>
                                            <TextBlock Text="▸  Remote Webcam"     Foreground="#8890B0" FontSize="11" Margin="0,3,14,3"/>
                                            <TextBlock Text="▸  File Execution"    Foreground="#8890B0" FontSize="11" Margin="0,3,0,3"/>
                                            <TextBlock Text="▸  Update Client"     Foreground="#8890B0" FontSize="11" Margin="0,3,14,3"/>
                                            <TextBlock Text="▸  Uninstall Client"  Foreground="#8890B0" FontSize="11" Margin="0,3,0,3"/>
                                            <TextBlock Text="▸  UAC Elevation"     Foreground="#8890B0" FontSize="11" Margin="0,3,14,3"/>
                                            <TextBlock Text="▸  UAC Loop"          Foreground="#8890B0" FontSize="11" Margin="0,3,0,3"/>
                                            <TextBlock Text="▸  AutoTask"          Foreground="#8890B0" FontSize="11" Margin="0,3,14,3"/>
                                            <TextBlock Text="▸  And more…"         Foreground="#5A6080" FontSize="11" Margin="0,3,0,3" FontStyle="Italic"/>
                                        </UniformGrid>
                                    </Border>
                                </StackPanel>

                                <!-- Telegram badge -->
                                <StackPanel HorizontalAlignment="Center" Margin="0,18,0,0">
                                    <TextBlock Text="C  O  N  T  A  C  T" HorizontalAlignment="Center"
                                               FontSize="12" FontWeight="SemiBold" Foreground="#303560"
                                               Margin="0,0,0,10"/>
                                    <Button HorizontalAlignment="Center" Cursor="Hand"
                                            Click="TelegramLink_Click"
                                            Background="Transparent" BorderThickness="0" Padding="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="TgBorder" CornerRadius="14" Padding="28,15"
                                                        BorderThickness="1">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#0A1428" Offset="0"/>
                                                            <GradientStop Color="#0D1A38" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.BorderBrush>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#702CA5E0" Offset="0"/>
                                                            <GradientStop Color="#704A85F5" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.BorderBrush>
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#2CA5E0" BlurRadius="22"
                                                                          ShadowDepth="0" Opacity="0.30"/>
                                                    </Border.Effect>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Image Source="/telegram.png" Width="24" Height="24"
                                                               VerticalAlignment="Center" Margin="0,0,12,0"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="@serotohnine" Foreground="#7AABFF"
                                                                       FontSize="14" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="TgBorder" Property="Opacity" Value="0.78"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="TgBorder" Property="Opacity" Value="0.50"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </TabItem>
            </TabControl>

            <!-- ── Status bar ─────────────────────────────────────── -->
            <Border Grid.Row="4" Background="#C0111222"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10" Padding="16,0">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#281E2038" Offset="0"/>
                        <GradientStop Color="#1E2038"   Offset="0.5"/>
                        <GradientStop Color="#281E2038" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="TxtStatusLeft" Text="SɆⱤØ RAT" Foreground="#2E3048"
                               FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" x:Name="TxtStatusBar" Text="Ready"
                               Foreground="#606880" FontSize="11"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
